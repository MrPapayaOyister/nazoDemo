# Copy to .env and set a real DB password. Placeholders only — NO real secrets here.

# Postgres — isolated db/role created by scripts/bootstrap_db.sh. psycopg v3 driver.
DATABASE_URL=postgresql+psycopg://nazo:CHANGEME@host.docker.internal:5432/nazo

# Qdrant — ONE isolated collection is created/used; other collections are untouched.
QDRANT_URL=http://host.docker.internal:6333
QDRANT_COLLECTION=nazo_library

# vLLM OpenAI-compatible server.
LLM_BASE_URL=http://host.docker.internal:9000/v1
LLM_MODEL=qwen2.5-32b

# Gotenberg (compose service; internal network only).
GOTENBERG_URL=http://gotenberg:3000

# API.
API_PORT=8200

# Reference-number allocation: EHCD/REQ/2026/031 first (REF_START=31, zero-pad 3).
REF_PREFIX=EHCD/REQ
REF_YEAR=2026
REF_START=31

# Embedding model id (used in later phases; qdrant vectors are size 1024 / Cosine).
EMBED_MODEL=BAAI/bge-m3

# Gmail (later phases). Paths only — mount real secrets at runtime.
GMAIL_CREDENTIALS=/secrets/credentials.json
GMAIL_TOKEN=/secrets/token.json
